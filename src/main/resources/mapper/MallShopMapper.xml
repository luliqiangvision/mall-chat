<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.treasurehunt.chat.mapper.MallShopMapper">

    <resultMap id="MallShopResultMap" type="com.treasurehunt.chat.domain.MallShopDO">
        <id property="id" column="id"/>
        <result property="shopId" column="shop_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="businessLine" column="business_line"/>
        <result property="shopName" column="shop_name"/>
        <result property="shopStatus" column="shop_status"/>
        <result property="shopIcon" column="shop_icon"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, shop_id, tenant_id, business_line, shop_name, shop_status, shop_icon, contact_phone, created_at, updated_at
    </sql>

    <select id="selectByShopId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE shop_id = #{shopId}
    </select>

    <select id="selectByBusinessLineAndId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE business_line = #{businessLine} AND shop_id = #{shopId}
    </select>

    <select id="selectByTenantId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE tenant_id = #{tenantId}
          AND shop_status = 'active'
        ORDER BY shop_name
    </select>

    <select id="selectByTenantIdAndStatus" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE tenant_id = #{tenantId}
          AND shop_status = #{shopStatus}
        ORDER BY shop_name
    </select>

    <select id="selectByBusinessLineAndTenantId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE business_line = #{businessLine}
          AND tenant_id = #{tenantId}
          AND shop_status = 'active'
        ORDER BY shop_name
    </select>

    <select id="selectByBusinessLineAndTenantIdAndStatus" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE business_line = #{businessLine}
          AND tenant_id = #{tenantId}
          AND shop_status = #{shopStatus}
        ORDER BY shop_name
    </select>

    <select id="selectByIdAndTenantId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE shop_id = #{shopId} AND tenant_id = #{tenantId}
    </select>

    <select id="selectByBusinessLineAndIdAndTenantId" resultMap="MallShopResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mall_shop
        WHERE business_line = #{businessLine} AND shop_id = #{shopId} AND tenant_id = #{tenantId}
    </select>

</mapper>
