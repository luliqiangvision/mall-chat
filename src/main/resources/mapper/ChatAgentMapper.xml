<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.treasurehunt.chat.mapper.ChatAgentMapper">

    <resultMap id="ChatAgentResultMap" type="com.treasurehunt.chat.domain.ChatAgentDO">
        <id property="id" column="id"/>
        <result property="agentId" column="agent_id"/>
        <result property="agentNo" column="agent_no"/>
        <result property="subjectId" column="subject_id"/>
        <result property="agentName" column="agent_name"/>
        <result property="password" column="password"/>
        <result property="agentType" column="agent_type"/>
        <result property="status" column="status"/>
        <result property="maxConcurrentConversations" column="max_concurrent_conversations"/>
        <result property="currentConversations" column="current_conversations"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="businessLine" column="business_line"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, agent_id, agent_no, subject_id, agent_name, password, agent_type, status,
        max_concurrent_conversations, current_conversations, tenant_id, business_line, created_at, updated_at
    </sql>

    <select id="selectBySubjectIdAndBusinessLine" resultMap="ChatAgentResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM chat_agent
        WHERE subject_id = #{subjectId}
          AND business_line = #{businessLine}
        ORDER BY status DESC, id ASC
    </select>

</mapper>

